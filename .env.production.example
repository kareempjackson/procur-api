# ─────────────────────────────────────────────────────────────────────────────
# Procur API — Production Environment Variables
# Copy to .env and fill in real values before deploying.
# ─────────────────────────────────────────────────────────────────────────────

NODE_ENV=production
PORT=3000

# ── Supabase ─────────────────────────────────────────────────────────────────
SUPABASE_URL=https://<project-ref>.supabase.co
SUPABASE_ANON_KEY=<anon-key>
SUPABASE_SERVICE_ROLE_KEY=<service-role-key>
SUPABASE_PRIVATE_BUCKET=private

# ── Auth ─────────────────────────────────────────────────────────────────────
JWT_SECRET=<at-least-32-char-random-string>
JWT_EXPIRES_IN=7d

# ── Redis ────────────────────────────────────────────────────────────────────
# Required for: session store, message queue, idempotency cache
REDIS_URL=redis://<host>:6379

# ── Email (Postmark) ─────────────────────────────────────────────────────────
POSTMARK_API_KEY=<postmark-server-api-token>
POSTMARK_FROM_EMAIL=noreply@procurapp.co

# ── Frontend ─────────────────────────────────────────────────────────────────
FRONTEND_URL=https://app.procurapp.co
LOGO_URL=https://app.procurapp.co/images/logos/procur-logo.png

# ── WhatsApp (Meta Cloud API) ─────────────────────────────────────────────────
# REQUIRED — WhatsApp bot will not start without these
WHATSAPP_TOKEN=<permanent-or-system-user-token>
WHATSAPP_PHONE_NUMBER_ID=<15-digit-phone-number-id>
WHATSAPP_WABA_ID=<whatsapp-business-account-id>

# REQUIRED — Used to verify webhook origin (set in Meta App > Webhooks)
WHATSAPP_VERIFY_TOKEN=<choose-a-random-string>

# REQUIRED in production — Used to validate HMAC-SHA256 webhook signatures
# Found at: Meta Developer Console > App > Basic Settings > App Secret
WHATSAPP_APP_SECRET=<app-secret>

# REQUIRED — Protects the /whatsapp/webhook/admin/token rotation endpoint
WHATSAPP_ADMIN_TOKEN=<choose-a-strong-random-string>

# Optional template name overrides (defaults are in template.service.ts)
WA_TEMPLATE_NEW_ORDER=new_order_to_seller_v1
WA_TEMPLATE_UPDATE_WITH_TRACKING=order_update_with_tracking_v1
WA_TEMPLATE_UPDATE_NO_TRACKING=order_update_no_tracking_v1
WA_TEMPLATE_OTP=otp_verify

# ── OpenAI (for AI/RAG features) ────────────────────────────────────────────
OPENAI_API_KEY=<openai-api-key>

# ── Stripe ───────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_live_<...>
STRIPE_PUBLISHABLE_KEY=pk_live_<...>
STRIPE_WEBHOOK_SECRET=whsec_<...>

# ── Sentry (error tracking) ──────────────────────────────────────────────────
SENTRY_DSN=https://<key>@sentry.io/<project>
SENTRY_TRACES_SAMPLE_RATE=0.1
SENTRY_PROFILES_SAMPLE_RATE=0.1

# ── Push Notifications ───────────────────────────────────────────────────────
FIREBASE_PROJECT_ID=<project-id>
FIREBASE_CLIENT_EMAIL=<service-account-email>
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
VAPID_PUBLIC_KEY=<vapid-public>
VAPID_PRIVATE_KEY=<vapid-private>
VAPID_SUBJECT=mailto:admin@procurapp.co

# ── Misc ─────────────────────────────────────────────────────────────────────
BANK_INFO_ENCRYPTION_KEY=<32-byte-hex-string>
RECAPTCHA_SECRET=<google-recaptcha-secret>
